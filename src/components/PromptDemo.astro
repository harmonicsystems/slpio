---
/**
 * Interactive prompt demo: shows pre-generated SLP prompt/response examples
 * with a typewriter animation. Zero API calls; pure CSS + vanilla JS.
 */

const demos = [
    {
        label: 'IEP Goal Writing',
        prompt: 'I have a 2nd grade student who omits /s/ clusters in all positions. She can produce /s/ in isolation. Write a measurable IEP goal.',
        response: `By the end of the IEP period, [Student] will produce /s/ clusters (e.g., /st/, /sp/, /sn/, /sl/) in the initial position of words with 80% accuracy across 3 consecutive data collection sessions, as measured by clinician observation during structured therapy activities.

**Short-term objectives:**
1. Produce /s/ clusters in the initial position of single words with 60% accuracy given visual/verbal cues
2. Produce /s/ clusters in initial position of phrases (3-5 words) with 70% accuracy given verbal cues only
3. Produce /s/ clusters in initial position during sentence-level tasks with 80% accuracy independently

**Why this works:** The goal builds from her current ability (/s/ in isolation) with a logical progression. It specifies position, accuracy criterion, and measurement method, all required for IDEA compliance.`,
    },
    {
        label: 'Progress Note',
        prompt: 'Write a SOAP note for a 78-year-old patient with moderate cognitive-linguistic impairment following a left CVA. Session focused on functional memory strategies.',
        response: `**S:** Patient reports difficulty remembering morning medication routine. States "I keep forgetting if I took my pills." Caregiver confirms missed doses 3x this week.

**O:** Patient participated in 45-min individual session targeting external memory strategy use. Trained use of daily checklist for medication management. Patient completed checklist with 70% accuracy given moderate verbal cues (4/6 trials). Recalled 2/5 items from a categorized grocery list using semantic cueing with min assist. Required max cues for self-initiated strategy use.

**A:** Patient demonstrates emerging ability to use external memory aids with cueing support. Functional carryover remains limited, dependent on caregiver prompts. Cueing hierarchy shows progress from max to mod assist over past 2 weeks. Current performance supports continued skilled intervention.

**P:** Continue 3x/week. Train caregiver in checklist prompting strategy. Introduce visual schedule for ADL sequencing next session.`,
    },
    {
        label: 'Parent Email',
        prompt: 'Draft a parent-friendly email explaining that their child qualified for speech services after a language evaluation. The child is 4 years old with receptive and expressive delays.',
        response: `Subject: Speech-Language Evaluation Results for [Child\'s Name]

Dear [Parent],

Thank you for bringing [Child] in for a speech-language evaluation. I wanted to share the results with you and talk about next steps.

After testing, we found that [Child] is having some difficulty in two areas:
- **Understanding language** (following directions, understanding questions, and learning new vocabulary)
- **Using language** (putting words together in sentences, telling about experiences, and using grammar)

These skills are developing a bit more slowly than we\'d expect for a child [their] age. The good news is that [Child] showed great strengths in social engagement and was very motivated during testing, both of which are really positive signs for progress.

Based on these results, [Child] qualifies for speech-language therapy. I\'d recommend starting with twice-weekly sessions focused on building vocabulary and sentence skills through play-based activities.

I\'d love to schedule a time to talk through the full report together and answer any questions. What works best for your schedule?

Warm regards,
[Your name], MS CCC-SLP`,
    },
    {
        label: 'Therapy Materials',
        prompt: 'Create 5 minimal pair cards for a child working on /k/ vs /t/ contrast in initial position. Make them kid-friendly with simple words.',
        response: `**Minimal Pair Cards: /k/ vs /t/ (Initial Position)**

| /k/ word | /t/ word | Visual Cue Idea |
|----------|----------|-----------------|
| **cap**  | **tap**  | baseball cap → water faucet |
| **key**  | **tea**  | gold key → teacup |
| **corn** | **torn** | ear of corn → ripped paper |
| **came** | **tame** | person arriving → gentle kitten |
| **coat** | **tote** | winter coat → tote bag |

**How to use these:**
1. Lay both cards face-up. Say one word; child points to the correct picture
2. Child says the word; you point to which one you heard (gives natural feedback)
3. If they say "tap" but mean "cap," pick up the faucet card to show why the difference matters

**Tip:** Start with the pairs where the pictures are most visually distinct (key/tea, corn/torn) before moving to harder contrasts.`,
    },
];
---

<div class="demo-section">
    <div class="section-header">
        <div class="section-label">See It In Action</div>
        <h2>Interactive <span class="accent">Demo</span></h2>
        <p class="section-intro">Watch how a well-crafted prompt produces clinically useful output. These are pre-generated examples: no API calls, no data sent anywhere.</p>
    </div>

    <div class="demo-container" id="prompt-demo">
        <div class="demo-tabs" id="demo-tabs">
            {demos.map((d, i) => (
                <button class={`demo-tab ${i === 0 ? 'active' : ''}`} data-index={i}>
                    {d.label}
                </button>
            ))}
        </div>

        <div class="demo-window">
            <div class="demo-toolbar">
                <div class="demo-dots">
                    <span class="dot red"></span>
                    <span class="dot yellow"></span>
                    <span class="dot green"></span>
                </div>
                <div class="demo-toolbar-title">SLP/IO Prompt Demo</div>
                <div class="demo-toolbar-spacer"></div>
            </div>

            <div class="demo-body">
                <div class="demo-prompt-section">
                    <div class="demo-role"><i class="ph ph-user"></i> Clinician</div>
                    <div class="demo-prompt-text" id="demo-prompt"></div>
                </div>

                <div class="demo-divider">
                    <span class="demo-divider-dot"></span>
                    <span class="demo-divider-dot"></span>
                    <span class="demo-divider-dot"></span>
                </div>

                <div class="demo-response-section">
                    <div class="demo-role ai"><i class="ph ph-robot"></i> AI Response <span class="demo-badge">requires clinical review</span></div>
                    <div class="demo-response-text" id="demo-response"></div>
                    <div class="demo-cursor" id="demo-cursor"></div>
                </div>

                <div class="demo-start-overlay" id="demo-start-overlay">
                    <button class="demo-start-btn" id="demo-start-btn">
                        <i class="ph ph-play-circle"></i> Run this prompt
                    </button>
                </div>
            </div>

            <div class="demo-footer-bar">
                <button class="demo-replay-btn" id="demo-replay" disabled>
                    <i class="ph ph-play"></i> Replay
                </button>
                <div class="demo-disclaimer">Pre-generated example, not live AI output</div>
            </div>
        </div>
    </div>
</div>

<script is:inline define:vars={{ demos }}>
(function() {
    let currentIndex = 0;
    let animationId = null;
    let promptTimeout = null;
    let hasStarted = false;

    const promptEl = document.getElementById('demo-prompt');
    const responseEl = document.getElementById('demo-response');
    const cursorEl = document.getElementById('demo-cursor');
    const tabs = document.querySelectorAll('.demo-tab');
    const replayBtn = document.getElementById('demo-replay');
    const startOverlay = document.getElementById('demo-start-overlay');
    const startBtn = document.getElementById('demo-start-btn');

    function clearAnimation() {
        if (animationId) cancelAnimationFrame(animationId);
        if (promptTimeout) clearTimeout(promptTimeout);
        animationId = null;
        promptTimeout = null;
    }

    function typeText(element, text, speed, callback) {
        let i = 0;
        element.innerHTML = '';
        cursorEl.style.display = 'inline-block';

        function tick() {
            if (i < text.length) {
                let char = text[i];
                i++;
                element.innerHTML = formatMarkdown(text.slice(0, i));
                element.closest('.demo-body').scrollTop = element.closest('.demo-body').scrollHeight;

                let delay = speed;
                if (char === '\n') delay = speed * 2;
                else if (char === '.' || char === '!' || char === '?') delay = speed * 1.5;
                else if (char === ',') delay = speed * 1.2;
                else if (char === '*') delay = 0;

                promptTimeout = setTimeout(() => {
                    animationId = requestAnimationFrame(tick);
                }, delay);
            } else {
                cursorEl.style.display = 'none';
                if (callback) callback();
            }
        }
        tick();
    }

    function formatMarkdown(text) {
        return text
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\|(.+)\|/g, function(match) {
                if (match.match(/^\|\s*[-:]+/)) return '<div class="md-table-sep"></div>';
                const cells = match.split('|').filter(c => c.trim()).map(c => '<span class="md-cell">' + c.trim() + '</span>');
                return '<div class="md-table-row">' + cells.join('') + '</div>';
            })
            .replace(/^(\d+)\.\s(.+)$/gm, '<div class="md-li"><span class="md-num">$1.</span> $2</div>')
            .replace(/\n/g, '<br/>');
    }

    function showPrompt(index) {
        currentIndex = index;
        const demo = demos[index];
        tabs.forEach((t, i) => t.classList.toggle('active', i === index));
        promptEl.textContent = demo.prompt;
        responseEl.innerHTML = '';
        cursorEl.style.display = 'none';

        if (!hasStarted) {
            startOverlay.style.display = 'flex';
            replayBtn.disabled = true;
        }
    }

    function runDemo(index) {
        clearAnimation();
        hasStarted = true;
        currentIndex = index;
        const demo = demos[index];

        tabs.forEach((t, i) => t.classList.toggle('active', i === index));
        startOverlay.style.display = 'none';
        replayBtn.disabled = false;

        promptEl.textContent = demo.prompt;
        responseEl.innerHTML = '';
        cursorEl.style.display = 'inline-block';

        promptTimeout = setTimeout(() => {
            typeText(responseEl, demo.response, 3, null);
        }, 400);
    }

    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            if (hasStarted) {
                runDemo(parseInt(tab.dataset.index));
            } else {
                showPrompt(parseInt(tab.dataset.index));
            }
        });
    });

    startBtn.addEventListener('click', () => {
        runDemo(currentIndex);
    });

    replayBtn.addEventListener('click', () => {
        runDemo(currentIndex);
    });

    // Show first prompt (but don't animate) on load
    showPrompt(0);
})();
</script>

