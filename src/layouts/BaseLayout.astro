---
import ChatWidget from '../components/ChatWidget.astro';
import Search from '../components/Search.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A free clinical knowledge resource for SLPs — because the people writing goals, reports, and session notes deserve to shape how that work gets done.' } = Astro.props;
const plainTitle = title.replace(/<[^>]+>/g, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{plainTitle} | SLP/IO</title>
    <meta name="description" content={description} />
    <meta name="author" content="David Nyman, MS CCC-SLP" />
    <meta name="keywords" content="SLP, speech-language pathology, LLM, AI, field guide, IEP, clinical documentation, ASHA, language models, generative AI, speech therapy, AAC" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${plainTitle} | SLP/IO`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:site_name" content="SLP/IO" />
    <meta property="og:image" content={new URL('/og-image.svg', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${plainTitle} | SLP/IO`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.svg', Astro.site).href} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script async src="https://plausible.io/js/pa-PTbvzPJNbkpKPC0Lyr8w0.js" is:inline></script>
    <script is:inline>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init();</script>
    <script src="https://unpkg.com/@phosphor-icons/web@2.1.1" is:inline></script>

    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "SLP/IO",
        "alternateName": "SLP IO Field Guide",
        "url": "https://www.slpio.org",
        "description": description,
        "author": {
            "@type": "Person",
            "name": "David Nyman",
            "credentials": "MS CCC-SLP",
            "jobTitle": "Speech-Language Pathologist",
        },
        "publisher": {
            "@type": "Organization",
            "name": "Harmonic Systems",
            "url": "https://github.com/harmonicsystems",
        },
        "inLanguage": "en-US",
        "about": {
            "@type": "Thing",
            "name": "Speech-Language Pathology and Artificial Intelligence",
        },
    })} />
</head>

<body>
    <header>
        <nav>
            <a href="/" class="logo">SLP/IO <span class="logo-badge">v3.0</span></a>
            <div class="hamburger" id="hamburger">
                <span></span><span></span><span></span>
            </div>
            <div class="nav-links" id="nav-links">
                <a href="/">Home</a>
                <a href="/foundations/">Foundations</a>
                <a href="/prompts/">Prompts</a>
                <a href="/workflows/">Workflows</a>
                <a href="/domains/">Domains</a>
                <div class="nav-more" id="nav-more">
                    <button class="nav-more-btn" id="nav-more-btn">More <i class="ph ph-caret-down"></i></button>
                    <div class="nav-dropdown" id="nav-dropdown">
                        <a href="/tasks/">Tasks</a>
                        <a href="/settings/">Settings</a>
                        <a href="/patterns/">Patterns</a>
                        <a href="/antipatterns/">Antipatterns</a>
                        <a href="/glossary/">Glossary</a>
                        <a href="/case-studies/">Case Studies</a>
                        <a href="/research/">Research</a>
                        <a href="/policies/">Policies</a>
                        <a href="/resources/">Resources</a>
                    </div>
                </div>
                <Search />
            </div>
            <div class="mobile-nav" id="mobile-nav">
                <div class="mobile-nav-group">
                    <div class="mobile-nav-label">Learn</div>
                    <a href="/foundations/">Foundations</a>
                    <a href="/glossary/">Glossary</a>
                    <a href="/research/">Research</a>
                </div>
                <div class="mobile-nav-group">
                    <div class="mobile-nav-label">Do</div>
                    <a href="/prompts/">Prompts</a>
                    <a href="/workflows/">Workflows</a>
                    <a href="/tasks/">Tasks</a>
                </div>
                <div class="mobile-nav-group">
                    <div class="mobile-nav-label">Adapt</div>
                    <a href="/domains/">Domains</a>
                    <a href="/settings/">Settings</a>
                    <a href="/patterns/">Patterns</a>
                </div>
                <div class="mobile-nav-group">
                    <div class="mobile-nav-label">Verify</div>
                    <a href="/antipatterns/">Antipatterns</a>
                    <a href="/case-studies/">Case Studies</a>
                    <a href="/policies/">Policies</a>
                    <a href="/resources/">Resources</a>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <slot />
    </main>

    <footer>
        <div class="footer-inner">
            <div class="footer-grid">
                <div class="footer-col">
                    <div class="footer-logo">SLP/IO</div>
                    <p class="footer-tagline">Speech-Language Pathology<br/>Innovation & Outreach</p>
                    <p class="footer-copy">&copy; 2025&ndash;2026 Harmonic Systems</p>
                </div>
                <div class="footer-col">
                    <div class="footer-heading">Explore</div>
                    <a href="/foundations/">Foundations</a>
                    <a href="/prompts/">Prompts</a>
                    <a href="/workflows/">Workflows</a>
                    <a href="/domains/">Domains</a>
                    <a href="/glossary/">Glossary</a>
                </div>
                <div class="footer-col">
                    <div class="footer-heading">Resources</div>
                    <a href="/case-studies/">Case Studies</a>
                    <a href="/research/">Research</a>
                    <a href="/policies/">Policies</a>
                    <a href="/patterns/">Patterns</a>
                    <a href="/resources/">Resources</a>
                </div>
                <div class="footer-col">
                    <div class="footer-heading">Connect</div>
                    <a href="https://github.com/harmonicsystems" target="_blank"><i class="ph ph-github-logo"></i> GitHub</a>
                    <a href="mailto:harmonicsystems.io@gmail.com"><i class="ph ph-envelope-simple"></i> Email</a>
                    <a href="https://reddit.com/r/slp" target="_blank"><i class="ph ph-reddit-logo"></i> r/slp</a>
                </div>
            </div>
            <div class="footer-bottom">
                <span>v3.0 &middot; Field Guide Edition &middot; Built in Kinderhook, NY</span>
                <span class="footer-dot">&middot;</span>
                <span>A <strong>Harmonic Systems</strong> project</span>
            </div>
        </div>
    </footer>

    <ChatWidget />

    <script is:inline>
        (function() {
            var hamburger = document.getElementById('hamburger');
            var navLinks = document.getElementById('nav-links');
            var mobileNav = document.getElementById('mobile-nav');
            var navMore = document.getElementById('nav-more');
            var navMoreBtn = document.getElementById('nav-more-btn');

            if (hamburger && mobileNav) {
                hamburger.addEventListener('click', function() {
                    hamburger.classList.toggle('open');
                    mobileNav.classList.toggle('open');
                });
                mobileNav.querySelectorAll('a').forEach(function(link) {
                    link.addEventListener('click', function() {
                        hamburger.classList.remove('open');
                        mobileNav.classList.remove('open');
                    });
                });
            }

            if (navMore && navMoreBtn) {
                navMoreBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    navMore.classList.toggle('open');
                });
                document.addEventListener('click', function(e) {
                    if (!navMore.contains(e.target)) {
                        navMore.classList.remove('open');
                    }
                });
            }
        })();
    </script>
</body>
</html>

<style is:global>
    @import '../styles/global.css';

    /* ── Header ── */
    header {
        position: fixed;
        top: 0;
        width: 100%;
        height: var(--header-height);
        background: color-mix(in srgb, var(--light) 85%, transparent);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        z-index: 1000;
        border-bottom: 1px solid var(--border);
    }

    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1100px;
        height: 100%;
        padding: 0 2rem;
        margin: auto;
    }

    .logo {
        font-family: "Roboto Mono", monospace;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
        letter-spacing: -0.5px;
        text-decoration: none;
        transition: letter-spacing 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .logo:hover { letter-spacing: 3px; color: var(--primary); }

    .logo-badge {
        font-size: 0.6rem;
        background: var(--primary);
        color: white;
        padding: 2px 6px;
        border-radius: 4px;
        vertical-align: super;
        margin-left: 6px;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .nav-links { display: flex; gap: 1.25rem; align-items: center; }

    .nav-links a {
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        color: var(--text-muted);
        transition: color var(--transition);
        font-size: 0.82rem;
        position: relative;
        text-decoration: none;
    }

    /* ── Nav Dropdown ── */
    .nav-more {
        position: relative;
    }

    .nav-more-btn {
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        color: var(--text-muted);
        font-size: 0.82rem;
        background: none;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 3px;
        padding: 0;
        transition: color var(--transition);
    }

    .nav-more-btn:hover { color: var(--primary); }
    .nav-more-btn i { font-size: 0.7rem; transition: transform 0.2s ease; }
    .nav-more.open .nav-more-btn i { transform: rotate(180deg); }

    .nav-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        min-width: 180px;
        background: color-mix(in srgb, var(--light) 97%, transparent);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border);
        border-radius: 10px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.1);
        padding: 0.5rem;
        z-index: 1001;
    }

    .nav-more.open .nav-dropdown { display: block; }

    .nav-dropdown a {
        display: block;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        font-size: 0.82rem;
        transition: background var(--transition);
    }

    .nav-dropdown a:hover { background: var(--primary-light); }
    .nav-dropdown a::after { display: none !important; }

    .nav-links a::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--primary);
        transition: width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        border-radius: 1px;
    }

    .nav-links a:hover { color: var(--primary); }
    .nav-links a:hover::after { width: 100%; }

    .hamburger {
        display: none;
        cursor: pointer;
        flex-direction: column;
        gap: 5px;
        padding: 8px;
        margin-right: -8px;
        -webkit-tap-highlight-color: transparent;
    }
    .hamburger span {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--dark);
        transition: transform 0.3s ease, opacity 0.2s ease;
        transform-origin: center;
    }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── Footer ── */
    footer {
        background: #0c1017;
        color: rgba(255,255,255,0.55);
        padding: 3.5rem 2rem 2rem;
        font-family: 'Poppins', sans-serif;
        font-size: 0.78rem;
    }

    .footer-inner { max-width: 960px; margin: auto; }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1fr;
        gap: 2.5rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .footer-col {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .footer-logo {
        font-family: "Roboto Mono", monospace;
        font-size: 1.25rem;
        font-weight: 700;
        color: rgba(255,255,255,0.85);
        letter-spacing: -0.5px;
        margin-bottom: 0.25rem;
    }

    .footer-tagline {
        font-size: 0.72rem;
        line-height: 1.5;
        color: rgba(255,255,255,0.4);
        margin-bottom: 0.75rem;
    }

    .footer-copy {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.3);
    }

    .footer-heading {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: rgba(255,255,255,0.7);
        margin-bottom: 0.5rem;
    }

    .footer-col a {
        color: rgba(255,255,255,0.45);
        text-decoration: none;
        transition: color var(--transition);
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .footer-col a:hover { color: #a8e6cf; }
    .footer-col a i { font-size: 0.85rem; }

    .footer-bottom {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding-top: 1.5rem;
        font-size: 0.65rem;
        color: rgba(255,255,255,0.25);
    }

    .footer-bottom strong { color: rgba(255,255,255,0.4); }

    /* ── Mobile Nav ── */
    .mobile-nav {
        display: none;
    }

    @media (max-width: 768px) {
        .nav-links { display: none !important; }
        .hamburger { display: flex; }

        .mobile-nav.open {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.25rem;
            position: fixed;
            top: var(--header-height);
            left: 0;
            right: 0;
            bottom: 0;
            background: var(--light);
            padding: 1.5rem 1.5rem 2rem;
            z-index: 999;
            overflow-y: auto;
            animation: navSlideIn 0.2s ease;
        }

        @keyframes navSlideIn {
            from { opacity: 0; transform: translateY(-8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .mobile-nav-group {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
        }

        .mobile-nav-label {
            font-family: 'Poppins', sans-serif;
            font-size: 0.6rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--primary);
            padding: 0 0.5rem;
            margin-bottom: 0.35rem;
        }

        .mobile-nav a {
            display: block;
            padding: 0.55rem 0.5rem;
            font-family: 'Poppins', sans-serif;
            font-size: 0.88rem;
            font-weight: 500;
            color: var(--dark);
            text-decoration: none;
            border-radius: 6px;
            transition: background var(--transition);
        }

        .mobile-nav a:hover {
            background: var(--primary-light);
            color: var(--primary);
        }

        .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
        .footer-bottom { flex-direction: column; gap: 0.25rem; }
        .footer-dot { display: none; }
    }
</style>
