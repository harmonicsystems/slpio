---
import ChatWidget from '../components/ChatWidget.astro';
import Search from '../components/Search.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A practical, clinician-first field guide for speech-language pathologists using language models responsibly in clinical and educational settings.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | SLP/IO</title>
    <meta name="description" content={description} />
    <meta name="author" content="David Nyman, MS CCC-SLP" />
    <meta name="keywords" content="SLP, speech-language pathology, LLM, AI, field guide, IEP, clinical documentation, ASHA, language models, generative AI, speech therapy, AAC" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | SLP/IO`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:site_name" content="SLP/IO" />
    <meta property="og:image" content={new URL('/og-image.svg', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | SLP/IO`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.svg', Astro.site).href} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script src="https://unpkg.com/@phosphor-icons/web@2.1.1" is:inline></script>

    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "SLP/IO",
        "alternateName": "SLP IO Field Guide",
        "url": "https://www.slpio.org",
        "description": description,
        "author": {
            "@type": "Person",
            "name": "David Nyman",
            "credentials": "MS CCC-SLP",
            "jobTitle": "Speech-Language Pathologist",
        },
        "publisher": {
            "@type": "Organization",
            "name": "Harmonic Systems",
            "url": "https://github.com/harmonicsystems",
        },
        "inLanguage": "en-US",
        "about": {
            "@type": "Thing",
            "name": "Speech-Language Pathology and Artificial Intelligence",
        },
    })} />
</head>

<body>
    <header>
        <nav>
            <a href="/" class="logo">SLP/IO <span class="logo-badge">v3.0</span></a>
            <div class="hamburger" id="hamburger">
                <span></span><span></span><span></span>
            </div>
            <div class="nav-links" id="nav-links">
                <a href="/">Home</a>
                <a href="/foundations/">Foundations</a>
                <a href="/prompts/">Prompts</a>
                <a href="/workflows/">Workflows</a>
                <a href="/domains/">Domains</a>
                <div class="nav-more" id="nav-more">
                    <button class="nav-more-btn" id="nav-more-btn">More <i class="ph ph-caret-down"></i></button>
                    <div class="nav-dropdown" id="nav-dropdown">
                        <a href="/tasks/">Tasks</a>
                        <a href="/settings/">Settings</a>
                        <a href="/patterns/">Patterns</a>
                        <a href="/antipatterns/">Antipatterns</a>
                        <a href="/glossary/">Glossary</a>
                        <a href="/resources/">Resources</a>
                    </div>
                </div>
                <Search />
            </div>
        </nav>
    </header>

    <main>
        <slot />
    </main>

    <div class="community-bar">
        <span>This is an open, evolving resource.</span>
        <a href="https://github.com/harmonicsystems" target="_blank"><i class="ph ph-github-logo"></i> Contribute on GitHub</a>
        <a href="https://reddit.com/r/slp" target="_blank"><i class="ph ph-reddit-logo"></i> Join the conversation</a>
    </div>

    <footer>
        <div class="footer-inner">
            <p>&copy; 2025&ndash;2026 <strong style="color:rgba(255,255,255,0.85)">Harmonic Systems</strong> &middot; SLP/IO &mdash; Speech-Language Pathology Innovation &amp; Outreach</p>
            <div class="social-icons">
                <a href="https://github.com/harmonicsystems" title="GitHub"><i class="ph ph-github-logo"></i></a>
                <a href="https://www.slpio.org" title="SLP/IO"><i class="ph ph-globe"></i></a>
                <a href="mailto:david@slpio.org" title="Email"><i class="ph ph-envelope-simple"></i></a>
            </div>
            <div class="footer-version">v3.0 &middot; Field Guide Edition &middot; A Harmonic Systems project &middot; Built in Kinderhook, NY</div>
        </div>
    </footer>

    <ChatWidget />

    <script is:inline>
        (function() {
            var hamburger = document.getElementById('hamburger');
            var navLinks = document.getElementById('nav-links');
            var navMore = document.getElementById('nav-more');
            var navMoreBtn = document.getElementById('nav-more-btn');

            if (hamburger && navLinks) {
                hamburger.addEventListener('click', function() {
                    hamburger.classList.toggle('open');
                    navLinks.classList.toggle('open');
                });
                navLinks.querySelectorAll('a').forEach(function(link) {
                    link.addEventListener('click', function() {
                        hamburger.classList.remove('open');
                        navLinks.classList.remove('open');
                        if (navMore) navMore.classList.remove('open');
                    });
                });
            }

            if (navMore && navMoreBtn) {
                navMoreBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    navMore.classList.toggle('open');
                });
                document.addEventListener('click', function(e) {
                    if (!navMore.contains(e.target)) {
                        navMore.classList.remove('open');
                    }
                });
            }
        })();
    </script>
</body>
</html>

<style is:global>
    @import '../styles/global.css';

    /* ── Header ── */
    header {
        position: fixed;
        top: 0;
        width: 100%;
        height: var(--header-height);
        background: color-mix(in srgb, var(--light) 85%, transparent);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        z-index: 1000;
        border-bottom: 1px solid var(--border);
    }

    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1100px;
        height: 100%;
        padding: 0 2rem;
        margin: auto;
    }

    .logo {
        font-family: "Roboto Mono", monospace;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
        letter-spacing: -0.5px;
        text-decoration: none;
        transition: letter-spacing 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .logo:hover { letter-spacing: 3px; color: var(--primary); }

    .logo-badge {
        font-size: 0.6rem;
        background: var(--primary);
        color: white;
        padding: 2px 6px;
        border-radius: 4px;
        vertical-align: super;
        margin-left: 6px;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .nav-links { display: flex; gap: 1.25rem; align-items: center; }

    .nav-links a {
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        color: var(--text-muted);
        transition: color var(--transition);
        font-size: 0.82rem;
        position: relative;
        text-decoration: none;
    }

    /* ── Nav Dropdown ── */
    .nav-more {
        position: relative;
    }

    .nav-more-btn {
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        color: var(--text-muted);
        font-size: 0.82rem;
        background: none;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 3px;
        padding: 0;
        transition: color var(--transition);
    }

    .nav-more-btn:hover { color: var(--primary); }
    .nav-more-btn i { font-size: 0.7rem; transition: transform 0.2s ease; }
    .nav-more.open .nav-more-btn i { transform: rotate(180deg); }

    .nav-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        min-width: 180px;
        background: color-mix(in srgb, var(--light) 97%, transparent);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border);
        border-radius: 10px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.1);
        padding: 0.5rem;
        z-index: 1001;
    }

    .nav-more.open .nav-dropdown { display: block; }

    .nav-dropdown a {
        display: block;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        font-size: 0.82rem;
        transition: background var(--transition);
    }

    .nav-dropdown a:hover { background: var(--primary-light); }
    .nav-dropdown a::after { display: none !important; }

    .nav-links a::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--primary);
        transition: width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        border-radius: 1px;
    }

    .nav-links a:hover { color: var(--primary); }
    .nav-links a:hover::after { width: 100%; }

    .hamburger {
        display: none;
        cursor: pointer;
        flex-direction: column;
        gap: 5px;
        padding: 8px;
        margin-right: -8px;
        -webkit-tap-highlight-color: transparent;
    }
    .hamburger span {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--dark);
        transition: transform 0.3s ease, opacity 0.2s ease;
        transform-origin: center;
    }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── Community Bar ── */
    .community-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        padding: 1.25rem 2rem;
        background: var(--dark);
        color: var(--light);
        font-size: 0.82rem;
        font-family: 'Poppins', sans-serif;
    }

    .community-bar a { color: #a8e6cf; font-weight: 600; transition: color var(--transition); text-decoration: none; }
    .community-bar a:hover { color: white; }

    /* ── Footer ── */
    footer {
        background: var(--dark);
        color: rgba(255,255,255,0.6);
        text-align: center;
        padding: 2.5rem 1rem 2rem;
        font-family: 'Poppins', sans-serif;
        font-size: 0.8rem;
    }

    .footer-inner { max-width: 960px; margin: auto; }

    .social-icons { display: flex; justify-content: center; gap: 1rem; margin-top: 1rem; }
    .social-icons a { color: rgba(255,255,255,0.5); font-size: 1.1rem; transition: color var(--transition); text-decoration: none; }
    .social-icons a:hover { color: white; }

    .footer-version { margin-top: 1rem; font-size: 0.7rem; color: rgba(255,255,255,0.3); }

    /* ── Mobile ── */
    @media (max-width: 768px) {
        .nav-links { display: none; }
        .hamburger { display: flex; }
        .nav-links.open {
            display: flex;
            flex-direction: column;
            position: absolute;
            top: var(--header-height);
            left: 0;
            width: 100%;
            background: color-mix(in srgb, var(--light) 97%, transparent);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            padding: 1.25rem 2rem 1.5rem;
            gap: 0.25rem;
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
            z-index: 999;
        }
        .nav-links.open a {
            padding: 0.65rem 0.5rem;
            font-size: 0.92rem;
            border-radius: 6px;
            transition: background var(--transition);
        }
        .nav-links.open a:hover { background: var(--primary-light); }
        .nav-links.open a::after { display: none; }
        .nav-more { width: 100%; }
        .nav-more-btn { padding: 0.65rem 0.5rem; font-size: 0.92rem; width: 100%; }
        .nav-dropdown {
            position: static;
            box-shadow: none;
            border: none;
            background: transparent;
            backdrop-filter: none;
            padding: 0 0 0 1rem;
            min-width: auto;
        }
        .nav-more .nav-dropdown { display: none; }
        .nav-more.open .nav-dropdown { display: block; }
        .nav-dropdown a { font-size: 0.88rem; }
        .community-bar { flex-direction: column; gap: 0.75rem; text-align: center; }
    }
</style>
