---
import BaseLayout from './BaseLayout.astro';
import Citations from '../components/Citations.astro';

interface Props {
  title: string;
  description?: string;
  label?: string;
  breadcrumbs?: Array<{ label: string; href: string }>;
}

const { title, description, label, breadcrumbs = [] } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const articleJsonLd = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description || '',
    "url": canonicalUrl,
    "author": {
        "@type": "Person",
        "name": "David Nyman",
        "credentials": "MS CCC-SLP",
    },
    "publisher": {
        "@type": "Organization",
        "name": "Harmonic Systems",
    },
    "mainEntityOfPage": canonicalUrl,
    "articleSection": label || '',
    "inLanguage": "en-US",
};
---

<BaseLayout title={title} description={description}>
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <section>
        {breadcrumbs.length > 0 && (
            <nav class="breadcrumb">
                <a href="/">Home</a>
                {breadcrumbs.map((crumb) => (
                    <><span>/</span><a href={crumb.href}>{crumb.label}</a></>
                ))}
                <span>/</span>{title}
            </nav>
        )}

        <div class="section-header">
            {label && <div class="section-label">{label}</div>}
            <h2><Fragment set:html={title} /></h2>
            {description && <p class="section-intro">{description}</p>}
        </div>

        <div class="prose">
            <slot />
        </div>
    </section>

    <Citations />

    <script is:inline>
    (function() {
        document.querySelectorAll('.prose pre').forEach(function(pre) {
            var wrap = document.createElement('div');
            wrap.className = 'code-block-wrap';
            pre.parentNode.insertBefore(wrap, pre);
            wrap.appendChild(pre);

            var btn = document.createElement('button');
            btn.className = 'copy-btn';
            btn.setAttribute('aria-label', 'Copy to clipboard');
            btn.innerHTML = '<i class="ph ph-copy"></i> Copy';
            wrap.appendChild(btn);

            btn.addEventListener('click', function() {
                var code = pre.querySelector('code');
                var text = (code || pre).textContent;
                navigator.clipboard.writeText(text).then(function() {
                    btn.innerHTML = '<i class="ph ph-check"></i> Copied!';
                    btn.classList.add('copied');
                    setTimeout(function() {
                        btn.innerHTML = '<i class="ph ph-copy"></i> Copy';
                        btn.classList.remove('copied');
                    }, 2000);
                });
            });
        });

        // Auto-detect FAQ sections and inject FAQPage JSON-LD
        var faqHeading = null;
        document.querySelectorAll('.prose h2').forEach(function(h2) {
            if (h2.textContent.trim().toLowerCase().indexOf('frequently asked questions') > -1) {
                faqHeading = h2;
            }
        });
        if (faqHeading) {
            var faqs = [];
            var el = faqHeading.nextElementSibling;
            var currentQ = null;
            while (el && el.tagName !== 'H2') {
                if (el.tagName === 'H3') {
                    if (currentQ) faqs.push(currentQ);
                    currentQ = { q: el.textContent.trim(), a: '' };
                } else if (currentQ && (el.tagName === 'P' || el.tagName === 'UL' || el.tagName === 'OL')) {
                    currentQ.a += (currentQ.a ? ' ' : '') + el.textContent.trim();
                }
                el = el.nextElementSibling;
            }
            if (currentQ) faqs.push(currentQ);
            if (faqs.length > 0) {
                var faqLd = {
                    "@context": "https://schema.org",
                    "@type": "FAQPage",
                    "mainEntity": faqs.map(function(f) {
                        return {
                            "@type": "Question",
                            "name": f.q,
                            "acceptedAnswer": { "@type": "Answer", "text": f.a }
                        };
                    })
                };
                var script = document.createElement('script');
                script.type = 'application/ld+json';
                script.textContent = JSON.stringify(faqLd);
                document.head.appendChild(script);
            }
        }
    })();
    </script>
</BaseLayout>

<style is:global>
    .code-block-wrap {
        position: relative;
    }

    .copy-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        font-family: 'Poppins', sans-serif;
        font-size: 0.68rem;
        font-weight: 600;
        color: rgba(255,255,255,0.5);
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
        z-index: 2;
    }

    .copy-btn:hover {
        color: rgba(255,255,255,0.9);
        background: rgba(255,255,255,0.15);
        border-color: rgba(255,255,255,0.2);
    }

    .copy-btn.copied {
        color: var(--accent-green);
        border-color: var(--accent-green);
        background: rgba(42,157,92,0.15);
    }

    .copy-btn i { font-size: 0.8rem; }
</style>
