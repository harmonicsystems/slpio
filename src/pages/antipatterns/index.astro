---
import SectionIndexLayout from '../../layouts/SectionIndexLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('antipatterns');
const sorted = entries.sort((a, b) => a.data.order - b.data.order);

const severityColors: Record<string, string> = {
    'critical': 'var(--accent-red)',
    'major': 'var(--accent-amber)',
    'minor': 'var(--text-muted)',
};
---

<SectionIndexLayout
    title="Anti<span class='accent'>patterns</span>"
    label="What Not to Do"
    description="Concrete before-and-after examples of bad LLM use in clinical practice. Each antipattern shows what went wrong, why the model produced it, and exactly how to fix it."
>
    {sorted.map((entry) => (
        <a href={`/antipatterns/${entry.id}/`} class="nav-card">
            <div style="display:flex; gap:0.5rem; margin-bottom:0.5rem;">
                <span class="severity-tag" style={`background: ${severityColors[entry.data.severity]}15; color: ${severityColors[entry.data.severity]};`}>
                    {entry.data.severity}
                </span>
                <span class="severity-tag" style="background: var(--secondary); color: var(--text-muted);">
                    {entry.data.category.replace(/-/g, ' ')}
                </span>
            </div>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.description}</p>
        </a>
    ))}
</SectionIndexLayout>

<style>
    .severity-tag {
        font-family: 'Poppins', sans-serif;
        font-size: 0.6rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 2px 8px;
        border-radius: 99px;
    }
</style>
