---
import ContentLayout from '../../layouts/ContentLayout.astro';
import AshaAlignment from '../../components/AshaAlignment.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const entries = await getCollection('tasks');
    return entries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const ashaTopicMap: Record<string, string[]> = {
    'writing-goals': ['ebp', 'ethics'],
    'documentation': ['documentation', 'ebp'],
    'communication': ['ethics', 'bilingual'],
    'compliance': ['documentation', 'ethics'],
    'clinical-reasoning': ['ebp', 'ethics'],
    'materials': ['ebp'],
};
const ashaTopics = ashaTopicMap[entry.id] || [];
---

<ContentLayout
    title={entry.data.title}
    description={entry.data.description}
    label="Tasks"
    breadcrumbs={[{ label: 'Tasks', href: '/tasks/' }]}
>
    <Content />
    <AshaAlignment topics={ashaTopics} />
</ContentLayout>
