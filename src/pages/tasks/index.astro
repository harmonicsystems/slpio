---
import SectionIndexLayout from '../../layouts/SectionIndexLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('tasks');
const sorted = entries.sort((a, b) => a.data.order - b.data.order);
---

<SectionIndexLayout
    title="<span class='accent'>Tasks</span>"
    label="Workflows by Task"
    description="The 'I need to do X right now' entry point. Each task includes domain-specific guidance, prompt templates, and before/after examples."
>
    {sorted.map((entry) => (
        <a href={`/tasks/${entry.id}/`} class="nav-card">
            {entry.data.icon && <i class={entry.data.icon} style="font-size:1.3rem; color:var(--primary); margin-bottom:0.75rem; display:block;"></i>}
            <h3>{entry.data.title}</h3>
            <p>{entry.data.description}</p>
        </a>
    ))}
</SectionIndexLayout>
