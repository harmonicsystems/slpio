---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const entries = await getCollection('prompts');
    return entries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout
    title={entry.data.title}
    description={entry.data.description}
    label="Prompt Library"
    breadcrumbs={[{ label: 'Prompts', href: '/prompts/' }]}
>
    <div class="prompt-meta">
        <span><strong>Category:</strong> {entry.data.category.replace('-', ' ')}</span>
        <span><strong>Settings:</strong> {entry.data.settings.join(', ')}</span>
        <span><strong>Populations:</strong> {entry.data.populations.join(', ')}</span>
        <span><strong>Difficulty:</strong> {entry.data.difficulty}</span>
    </div>
    <Content />
</ContentLayout>

<style is:global>
    .prompt-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: var(--secondary);
        border-radius: var(--radius);
        margin-bottom: 2rem;
        font-size: 0.78rem;
        color: var(--text-muted);
        font-family: 'Poppins', sans-serif;
        text-transform: capitalize;
    }
</style>
