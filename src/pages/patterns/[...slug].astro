---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const entries = await getCollection('patterns');
    return entries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout
    title={entry.data.title}
    description={entry.data.description}
    label="Clinical Patterns"
    breadcrumbs={[{ label: 'Patterns', href: '/patterns/' }]}
>
    <div class="pattern-meta">
        <span><strong>Clinical orientation:</strong> {entry.data.clinicalOrientation}</span>
        {entry.data.contrasts && <span><strong>Contrasts with:</strong> {entry.data.contrasts}</span>}
        <span><strong>Settings:</strong> {entry.data.settings.join(', ')}</span>
    </div>
    <Content />
</ContentLayout>

<style is:global>
    .pattern-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: var(--secondary);
        border-radius: var(--radius);
        margin-bottom: 2rem;
        font-size: 0.78rem;
        color: var(--text-muted);
        font-family: 'Poppins', sans-serif;
        text-transform: capitalize;
    }
</style>
