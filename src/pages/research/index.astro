---
import SectionIndexLayout from '../../layouts/SectionIndexLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('research');
const sorted = entries.sort((a, b) => a.data.order - b.data.order);

const relevanceColors: Record<string, string> = {
    'direct': 'var(--accent-green)',
    'cross-disciplinary': 'var(--accent-amber)',
    'foundational': 'var(--primary)',
};
---

<SectionIndexLayout
    title="Research <span class='accent'>Digests</span>"
    label="Evidence Base"
    description="Structured summaries of peer-reviewed research relevant to AI use in speech-language pathology. Each digest explains what the study found and why it matters for clinical practice."
>
    {sorted.map((entry) => (
        <a href={`/research/${entry.id}/`} class="nav-card">
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.5rem;">
                <span class="research-tag" style={`background: ${relevanceColors[entry.data.relevance] || 'var(--primary)'}15; color: ${relevanceColors[entry.data.relevance] || 'var(--primary)'};`}>
                    {entry.data.relevance}
                </span>
                <span class="research-tag" style="background: var(--secondary); color: var(--text-muted);">
                    {entry.data.year}
                </span>
            </div>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.description}</p>
            <div style="margin-top:0.5rem; font-size:0.72rem; color:var(--text-muted);">
                {entry.data.authors} · <em>{entry.data.journal}</em>
            </div>
        </a>
    ))}
</SectionIndexLayout>

<style>
    .research-tag {
        font-family: 'Poppins', sans-serif;
        font-size: 0.6rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 2px 8px;
        border-radius: 99px;
    }
</style>
