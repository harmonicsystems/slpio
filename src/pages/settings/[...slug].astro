---
import ContentLayout from '../../layouts/ContentLayout.astro';
import AshaAlignment from '../../components/AshaAlignment.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const entries = await getCollection('settings');
    return entries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const ashaTopicMap: Record<string, string[]> = {
    'schools': ['ethics', 'ebp', 'bilingual'],
    'medical-acute': ['documentation', 'dysphagia', 'ethics'],
    'snf-rehab': ['documentation', 'cognitive-linguistic', 'dementia'],
    'early-intervention': ['early-intervention', 'late-language-emergence'],
    'private-practice': ['telepractice', 'ethics', 'documentation'],
    'university-supervision': ['supervision', 'ethics'],
};
const ashaTopics = ashaTopicMap[entry.id] || [];
---

<ContentLayout
    title={entry.data.title}
    description={entry.data.description}
    label="Settings"
    breadcrumbs={[{ label: 'Settings', href: '/settings/' }]}
>
    <Content />
    <AshaAlignment topics={ashaTopics} />
</ContentLayout>
