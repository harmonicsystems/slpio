---
import SectionIndexLayout from '../../layouts/SectionIndexLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('domains');
const sorted = entries.sort((a, b) => a.data.order - b.data.order);
---

<SectionIndexLayout
    title="Clinical <span class='accent'>Domains</span>"
    label="Clinical Specialties"
    description="Deep dives into each clinical area across the SLP scope of practice. Each domain covers LLM strengths, limitations, goal examples, and cross-references to relevant tasks and settings."
>
    {sorted.map((entry) => (
        <a href={`/domains/${entry.id}/`} class="nav-card">
            {entry.data.icon && <i class={entry.data.icon} style="font-size:1.3rem; color:var(--primary); margin-bottom:0.75rem; display:block;"></i>}
            <h3>{entry.data.title}</h3>
            <p>{entry.data.description}</p>
        </a>
    ))}
</SectionIndexLayout>
